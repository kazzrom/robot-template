{
    "name": "Robot Framework Dev",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": "..",
        "target": "dev"
    },
    "forwardPorts": [6080],
    "portsAttributes": {
        "6080": {
            "label": "Browser View (noVNC)",
            "onAutoForward": "openPreview" // Откроет окно рядом с кодом
        }
    },
    "containerEnv": {
        "UV_PROJECT_ENVIRONMENT": "/home/pwuser/.venv",
        "DISPLAY": ":99"
    },
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
        "source=vscode-extensions,target=/root/.vscode-server/extensions,type=volume",
        "source=${localEnv:USERPROFILE}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "d-biehl.robotcode",
                "charliermarsh.ruff",
                "Codeium.codeium"
            ],
            "settings": {
                // Указываем RobotCode конкретный интерпретатор из venv
                "robotcode.robot.python.executable": "/home/pwuser/.venv/bin/python",
                "python.defaultInterpreterPath": "/home/pwuser/.venv/bin/python",
                "python.terminal.activateEnvironment": true
            }
        }
    },
    "remoteUser": "root"
}
